# ── 管理员认证 ──
ADMIN_PASSWORD=change-me
ADMIN_TOKEN_SALT=change-me-to-a-random-string
AI_CONFIG_ENCRYPTION_SECRET=change-me-to-another-random-string

# ── 站点配置 ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── 社交账号（Twitter / X，可选，不配则不显示相关链接和元信息）──
# NEXT_PUBLIC_TWITTER_HANDLE=your-handle
# NEXT_PUBLIC_TWITTER_URL=https://x.com/your-handle/

# ── Giscus 评论（基于 GitHub Discussions） ──
# 前往 https://giscus.app/zh-CN 配置并获取这些参数
# NEXT_PUBLIC_GISCUS_REPO=你的GitHub用户名/仓库名
# NEXT_PUBLIC_GISCUS_REPO_ID=你的仓库ID
# NEXT_PUBLIC_GISCUS_CATEGORY_ID=你的分类ID

# ── AI 服务（可选） ──
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
WORKERS_AI_MODEL=@cf/meta/llama-3.1-8b-instruct

# ── Cloudflare 增强功能（可选） ──
ENABLE_BACKGROUND_JOBS=
ENABLE_WORKERS_AI=
ENABLE_VECTOR_SEARCH=
ENABLE_CF_IMAGE_PIPELINE=
ENABLE_PUBLIC_CACHE_IN_DEV=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
